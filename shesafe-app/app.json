{
  "expo": {
    "name": "SheSafe",
    "slug": "shesafe-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0523"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shesafe.app"
    },
    "android": {
      "package": "com.shesafe.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4c1d95"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SheSafe needs your location to detect danger zones."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d21db62e-f00e-47ee-b935-d213fd50ee59"
      }
    }
  }
}
