# SHESAFE Backend Environment Variables
# Copy this to .env and fill in your values

# ── Twilio ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ── Firebase ──
FIREBASE_CREDENTIALS_PATH=firebase_service_account.json
FIREBASE_STORAGE_BUCKET=

# ── App ──
DEBUG=true
